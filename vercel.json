{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "env": {
    "REACT_APP_VERSION": "1.0.0"
  },
  "routes": [
    {
      "src": "/[^.]+$",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "src": "/static/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    }
  ]
}
